# Copia este archivo a .env.local y completa los valores
# NO subas .env.local a GitHub

# Clave de https://resend.com/api-keys
RESEND_API_KEY=

# Remitente (dominio verificado en Resend o onboarding@resend.dev para pruebas)
BCA_FROM_EMAIL=Black Coffee <onboarding@resend.dev>

# Token de: npx firebase login:ci
FIREBASE_TOKEN=
